# Required: Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Required: Cloudflare R2 bucket credentials and public asset base URL.
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Required: generate a strong random secret for better-auth.
BETTER_AUTH_SECRET=your_strong_random_secret
# Required: canonical app URL used by better-auth.
BETTER_AUTH_URL=http://localhost:3000
# Optional on Vercel: preview and production hostnames.
VERCEL_URL=ycc-website.vercel.app
VERCEL_PROJECT_PRODUCTION_URL=ycc-website.vercel.app

# Required: Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Required: Cloudflare R2 bucket credentials and public asset base URL.
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Required: generate a strong random secret for better-auth.
BETTER_AUTH_SECRET=your_strong_random_secret
# Required: canonical app URL used by better-auth.
BETTER_AUTH_URL=http://localhost:3000
# Canonical production URL (www is the primary domain; keep www to match).
NEXT_PUBLIC_SITE_URL=https://www.ycjc.kr
# On Vercel these are auto-provided system vars — do NOT set manually
# (a manual VERCEL_PROJECT_PRODUCTION_URL overrides the real domain and breaks auth origins).
# VERCEL_URL=<auto>
# VERCEL_PROJECT_PRODUCTION_URL=<auto>

# Gemini — gemini-3.5-flash
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.5-flash

# OpenAI — 썸네일 배경 이미지 생성(gpt-image-2)
OPENAI_API_KEY=your_openai_api_key

# remove.bg — 인물컷형 썸네일 누끼(배경 제거)
REMOVE_BG_API_KEY=your_remove_bg_api_key

# QStash
# 정기 스케줄(WebSub 갱신 2일·요약 재시도 매시간)은 `npm run qstash:schedules` 1회 실행으로 등록/갱신(멱등).
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_qstash_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_qstash_next_signing_key

# RapidAPI yt-api (채널 영상 목록 + 자막 공용 호스트, 예: yt-api.p.rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=yt-api.p.rapidapi.com
# 하위호환: RAPIDAPI_HOST 미설정 시 폴백으로 사용됨
RAPIDAPI_TRANSCRIPT_HOST=youtube-transcript3.p.rapidapi.com

# WebSub (콜백 URL은 사이트 origin + /api/youtube/websub 로 코드에서 합성)
WEBSUB_SECRET=your_websub_secret
# 공개 채널 ID (영천중앙교회)
YOUTUBE_CHANNEL_ID=UCzB3UsqsJhtFUvPEeOtTL6g

#방문자 분석용 SALT (랜덤 문자열, 32바이트 이상 권장)
ANALYTICS_SALT=your_analytics_salt